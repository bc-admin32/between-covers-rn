{
  "expo": {
    "name": "Between Covers",
    "slug": "BetweenCovers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "betweencovers",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.betweencovers.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.betweencovers.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0d"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
